# 本番サイトのURL（OGPやsitemapの絶対URLに使用）
NEXT_PUBLIC_SITE_URL=https://zeical.jp

# Google Analytics 4 の測定ID（例: G-XXXXXXXXXX）。未設定なら計測は無効
NEXT_PUBLIC_GA_ID=

# Google AdSense のパブリッシャーID
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-5820360156544018

# 広告ユニットのスロットID（AdSense管理画面 > 広告 > 広告ユニット で発行）
NEXT_PUBLIC_ADSENSE_SLOT_RESULT=
NEXT_PUBLIC_ADSENSE_SLOT_STICKY=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=

# 運営者の連絡先メール（運営者情報・プライバシーポリシーに表示）
NEXT_PUBLIC_CONTACT_EMAIL=

# Supabase（記事・コンテンツ管理）。未設定の場合はサンプル記事で動作します
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
